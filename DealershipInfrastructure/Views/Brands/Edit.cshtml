@model DealershipDomain.Model.Brand

@{
    ViewData["Title"] = "Редагування бренду";
}

<h1>Редагування бренду</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Country" class="form-label fw-semibold"></label>
                <select asp-for="Country" class="form-select">
                    <option value="">Оберіть країну...</option>
                    <option value="Японія">Японія</option>
                    <option value="Німеччина">Німеччина</option>
                    <option value="США">США</option>
                    <option value="Південна Корея">Південна Корея</option>
                    <option value="Франція">Франція</option>
                    <option value="Італія">Італія</option>
                    <option value="Велика Британія">Велика Британія</option>
                    <option value="Швеція">Швеція</option>
                    <option value="Китай">Китай</option>
                </select>
                <span asp-validation-for="Country" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="✅ Зберегти зміни" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">← Назад до списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
