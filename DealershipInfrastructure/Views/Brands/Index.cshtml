@model IEnumerable<DealershipDomain.Model.Brand>

@{
    ViewData["Title"] = "Бренди";
}

<h1>Список брендів</h1>

<p class="mb-4">
    <a asp-action="Create" class="btn btn-primary">
        ➕ Додати новий бренд
    </a>
</p>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Country)</th>
                    <th class="text-center">Кількість авто</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle fw-semibold">@Html.DisplayFor(modelItem => item.Name)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.Country)</td>
                        <td class="align-middle text-center">
                            <span class="badge bg-secondary">@item.Cars.Count</span>
                        </td>
                        <td class="text-end align-middle">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">✏️ Редагувати</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">🚗 Автомобілі</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">🗑️ Видалити</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
